{
  "server": {
    "address": "0.0.0.0",
    "port": 8080,
    "workers": 2,
    "max_connections": 2048,
    "static_root": "/app/static"
  },
  "timeouts": {
    "idle_ms": 30000,
    "header_ms": 5000,
    "body_ms": 15000,
    "write_ms": 15000
  },
  "upstreams": [
    {
      "name": "api",
      "servers": [
        { "address": "api-service", "port": 3000 }
      ],
      "health_check": {
        "path": "/health",
        "interval_ms": 5000
      }
    }
  ],
  "routes": [
    {
      "path_prefix": "/api/",
      "upstream": "api",
      "rewrite_pattern": "/api",
      "rewrite_replacement": ""
    }
  ]
}
